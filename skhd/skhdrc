# change window focus
lalt - k : yabai -m window --focus south
lalt - j : yabai -m window --focus north
lalt - h : yabai -m window --focus west
lalt - l : yabai -m window --focus east

# window resizing
:: resize @ : yabai -m conig active_window_border_color 0x00ff0000

# # resize mode
hyper - r ; resize # enter resize mode using HYPER + r
resize < hyper - r ; default # exit resize mode using the same

resize < h : yabai -m window --resize right:-20:0 2> /dev/null || yabai -m window --resize left:-20:0 2> /dev/null
resize < j : yabai -m window --resize bottom:0:20 2> /dev/null || yabai -m window --resize top:0:20 2> /dev/null
resize < k : yabai -m window --resize bottom:0:-20 2> /dev/null || yabai -m window --resize top:0:-20 2> /dev/null
resize < l : yabai -m window --resize right:20:0 2> /dev/null || yabai -m window --resize left:20:0 2> /dev/null
# #

lalt - m : yabai -m window --toggle zoom-fullscreen
lalt - b : yabai -m space --balance

# move all windows clockwise/counterclockwise
lshift + lalt - right: yabai -m space --rotate 270
lshift + lalt - left: yabai -m space --rotate 90

# move window to display left and right
lshift + ralt - left: yabai -m window --display west; yabai -m display --focus west
lshift + ralt - right: yabai -m window --display east; yabai -m display --focus east

# swap windows
# # swap mode
hyper - s ; swap # enter swap mode using HYPER + s
swap < hyper - s ; defaut

swap < j : yabai -m window --swap north
swap < k : yabai -m widow --swap south
swap < h  : yabai -m window --swap west
swap < l : yabai -m window --swap east

# toggle float window for the selected window
lalt - f : yabai -m window --toggle float --grid 4:4:1:1:2:2


######### display #########
# change display focus
ralt - right: yabai -m display --focus east
ralt - left: yabai -m display --focus west

######### space #########
rshift + ralt - right: yabai -m window --space next --display recent
rshift + ralt - left: yabai -m window --space prev --display recent


